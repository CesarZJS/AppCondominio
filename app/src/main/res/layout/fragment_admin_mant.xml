<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Fondo con círculos decorativos (mismo que usas) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_circles" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingTop="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Título -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Horarios"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:shadowColor="#20000000"
                        android:shadowDx="2"
                        android:shadowDy="2"
                        android:shadowRadius="4" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mantenimiento de Áreas Comunes"
                        android:textSize="18sp"
                        android:textColor="#CCFFFFFF" />
                </LinearLayout>
            </LinearLayout>

            <!-- Card de selección -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Seleccionar Área Común"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#2C3E50"
                        android:layout_marginBottom="16dp" />

                    <!-- Spinner para torres -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Seleccionar Torre"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_marginBottom="16dp">

                        <androidx.appcompat.widget.AppCompatSpinner
                            android:id="@+id/spinnerTorre"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:entries="@array/torres_array" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Spinner para áreas comunes -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Seleccionar Área Común"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_marginBottom="16dp">

                        <androidx.appcompat.widget.AppCompatSpinner
                            android:id="@+id/spinnerAreaComun"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:entries="@array/areas_comunes_array" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Botón cargar -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCargar"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Cargar Horarios"
                        android:textAllCaps="false"
                        app:cornerRadius="28dp"
                        android:backgroundTint="#0D6790" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card de horarios -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHorarios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF"
                android:visibility="gone"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/txtAreaSeleccionada"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1E3A5F"
                        android:layout_marginBottom="16dp" />

                    <!-- Rango de fechas -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Rango de Fechas"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#0D6790"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="24dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Fecha Desde"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_marginEnd="8dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etFechaDesde"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="date" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Fecha Hasta"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_marginStart="8dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etFechaHasta"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="date" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Rango de horas -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Rango de Horas"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#0D6790"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="24dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Hora Desde"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_marginEnd="8dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etHoraDesde"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="08:00"
                                android:inputType="time" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Hora Hasta"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_marginStart="8dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etHoraHasta"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="20:00"
                                android:inputType="time" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Estado -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Estado del Área"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#0D6790"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipDisponible"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✅ Disponible"
                            android:checked="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipMantenimiento"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔧 En Mantenimiento" />

                    </com.google.android.material.chip.ChipGroup>

                    <!-- Botón guardar -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGuardar"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Guardar"
                        android:textAllCaps="false"
                        app:cornerRadius="28dp"
                        android:backgroundTint="#0D6790" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card de mantenimiento programado -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMantenimiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF"
                android:visibility="gone"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Programar Mantenimiento"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#2C3E50"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Fecha de Mantenimiento"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etFechaMantenimiento"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="date"
                            android:text="2026-04-10" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Descripción del mantenimiento"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDescripcionMantenimiento"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Limpieza general y revisión de equipos"
                            android:maxLines="3" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAgregarMantenimiento"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Agregar"
                        android:textAllCaps="false"
                        app:cornerRadius="28dp"
                        android:backgroundTint="#0D6790" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardListaMantenimientos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📋 Mantenimientos Programados"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#2C3E50"
                        android:layout_marginBottom="16dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvMantenimientos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Mensaje sin resultados -->
            <TextView
                android:id="@+id/txtSinResultados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🏢 Selecciona una torre y un área común"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:visibility="gone"
                android:background="#80FFFFFF"
                android:padding="32dp" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>