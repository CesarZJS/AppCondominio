<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Fondo con círculos decorativos -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_circles" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingTop="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Encabezado con saludo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Bienvenido,"
                        android:textSize="25sp"
                        android:textColor="#CCFFFFFF" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Administrador"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />
                </LinearLayout>

                <!-- Foto de perfil circular -->
                <ImageView
                    android:id="@+id/imgFotoPerfil"
                    android:paddingTop="10dp"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/img_icono"
                    />
            </LinearLayout>

            <!-- Tarjetas de resumen (Scroll horizontal) -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Card Torre -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="160dp"
                        android:layout_height="100dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="#FFFFFF"
                        android:layout_marginEnd="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🏢"
                                android:textSize="32sp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:id="@+id/txtTotalTorres"

                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="5"
                                    android:textSize="24sp"
                                    android:textStyle="bold"
                                    android:textColor="#1E3A5F" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Torres"
                                    android:textSize="12sp"
                                    android:textColor="#666666" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Card Departamentos -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="160dp"
                        android:layout_height="100dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="#FFFFFF"
                        android:layout_marginEnd="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🏠"
                                android:textSize="32sp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:id="@+id/txtTotalDeptos"

                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="130"
                                    android:textSize="24sp"
                                    android:textStyle="bold"
                                    android:textColor="#1E3A5F" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Deptos"
                                    android:textSize="12sp"
                                    android:textColor="#666666" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Card Propietarios -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="160dp"
                        android:layout_height="100dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="#FFFFFF"
                        android:layout_marginEnd="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="👥"
                                android:textSize="32sp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:id="@+id/txtTotalPropietarios"

                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="98"
                                    android:textSize="24sp"
                                    android:textStyle="bold"
                                    android:textColor="#1E3A5F" />

                                <TextView
                                    android:id="@+id/txtTotalIngresos"

                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Propietarios"
                                    android:textSize="12sp"
                                    android:textColor="#666666" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Card Ingresos -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="160dp"
                        android:layout_height="100dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="#4CAF50">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💰"
                                android:textSize="32sp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="S/ 12,450"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="#FFFFFF" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Este mes"
                                    android:textSize="11sp"
                                    android:textColor="#CCFFFFFF" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Gráfico de ingresos (simulado) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ingresos Mensuales"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1E3A5F"
                        android:layout_marginBottom="16dp" />

                    <!-- Barras del gráfico -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:orientation="horizontal"
                        android:gravity="bottom">

                        <!-- Barra Julio -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="bottom">

                            <View
                                android:id="@+id/barraJul"
                                android:layout_width="match_parent"
                                android:layout_height="80dp"
                                android:background="#0D6790"
                                android:layout_margin="4dp"
                                app:cornerRadius="8dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Jul"
                                android:textSize="10sp"
                                android:textColor="#666666"
                                android:gravity="center" />
                        </LinearLayout>

                        <!-- Barra Agosto -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="bottom">

                            <View
                                android:id="@+id/barraAgo"
                                android:layout_width="match_parent"
                                android:layout_height="95dp"
                                android:background="#0D6790"
                                android:layout_margin="4dp"
                                app:cornerRadius="8dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Ago"
                                android:textSize="10sp"
                                android:textColor="#666666"
                                android:gravity="center" />
                        </LinearLayout>

                        <!-- Barra Septiembre -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="bottom">

                            <View
                                android:id="@+id/barraSep"
                                android:layout_width="match_parent"
                                android:layout_height="70dp"
                                android:background="#0D6790"
                                android:layout_margin="4dp"
                                app:cornerRadius="8dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Sep"
                                android:textSize="10sp"
                                android:textColor="#666666"
                                android:gravity="center" />
                        </LinearLayout>

                        <!-- Barra Octubre -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="bottom">

                            <View
                                android:id="@+id/barraOct"
                                android:layout_width="match_parent"
                                android:layout_height="110dp"
                                android:background="#0D6790"
                                android:layout_margin="4dp"
                                app:cornerRadius="8dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Oct"
                                android:textSize="10sp"
                                android:textColor="#666666"
                                android:gravity="center" />
                        </LinearLayout>

                        <!-- Barra Noviembre -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="bottom">

                            <View
                                android:id="@+id/barraNov"
                                android:layout_width="match_parent"
                                android:layout_height="100dp"
                                android:background="#0D6790"
                                android:layout_margin="4dp"
                                app:cornerRadius="8dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Nov"
                                android:textSize="10sp"
                                android:textColor="#666666"
                                android:gravity="center" />
                        </LinearLayout>

                        <!-- Barra Diciembre -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="bottom">

                            <View
                                android:id="@+id/barraDic"
                                android:layout_width="match_parent"
                                android:layout_height="120dp"
                                android:background="#4CAF50"
                                android:layout_margin="4dp"
                                app:cornerRadius="8dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Dic"
                                android:textSize="10sp"
                                android:textColor="#666666"
                                android:gravity="center"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
